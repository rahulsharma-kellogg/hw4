<h1>New Entry</h1>

<% if @user != nil %>
  <form action="/entries" method="post" enctype="multipart/form-data">
    <input type="hidden" name="place_id" value="<%= params["place_id"] %>">

    <p>
      <label for="title_input">Title</label>
      <input type="text" name="title" id="title_input">
    </p>

    <p>
      <label for="description_input">Description</label>
      <input type="text" name="description" id="description_input">
    </p>

    <p>
      <label for="uploaded_image_input" class="form-label">Upload Image</label>
      <input type="file" name="uploaded_image" id="uploaded_image_input" class="form-control" accept="image/png, image/jpg, image/jpeg, image/gif">
    </p>

    <p>
      <label for="occurred_on_input">Occurred On</label>
      <input type="date" name="occurred_on" id="occurred_on_input">
    </p>

    <button class="btn btn-outline-dark border-3 px-4 py-2 fw-bold">Save</button>
  </form>
<% else %>
  <p> Please <a href="/login">log in</a> to add a new entry to your travel log!
<% end %>