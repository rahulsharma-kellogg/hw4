<h1>Places</h1>

<% @user = User.find_by({"id" => session["user_id"]}) %>
<% if @user != nil%>
  <ul>
    <% for place in @places %>
      <li><a href="/places/<%= place["id"] %>"><%= place["name"] %></a></li>
    <% end %>
  </ul>

  <p>
    <a href="/places/new">New place</a>
  </p>
<% else %>
  <p> 
    Please <a href="/login">log in</a> to view your travel log!
  </p>
<% end %>