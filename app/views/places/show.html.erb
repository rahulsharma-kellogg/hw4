<h1 class="mb-3"><%= @place["name"] %></h1>

<p class="mb-3">
  <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-outline-dark fw-bold px-4 py-2">New Entry</a>
</p>

<div class="row g-4">
  <% for entry in @entries %>
    <% if entry["user_id"] == session["user_id"]%>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="h-100">
          <h3 class="fw-bold mb-1"><%= entry["title"] %></h3>
          <p class="text-muted small mb-3"><%= entry["occurred_on"] %></p>
          <% if entry.uploaded_image.attached? %>
            <img src="<%= url_for(entry.uploaded_image) =%>" class="img-fluid mb-3 w-100">
          <% else %>
            <div class="border bg-white w-100 mb-3" style="height: 250px;"></div>
          <% end %>
          <p class="mb-0"><%= entry["description"] %></p>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<p class="mt-4">
  <a href="/places">Back to All Places</a>
</p>