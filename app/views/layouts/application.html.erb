<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <div>
      <%= flash["notice"] %>
    </div>
    <div>
      <% @user = User.find_by({"id" => session["user_id"]}) %>
      <% if @user == nil %>
        <a href="/">Home</a> | <a href="/login">Login</a> | <a href="/users/new">Signup</a>
      <% else %>
        Hi <%= @user["username"] =%>! | <a href="/">Home</a> | <a href="/logout">Logout</a>
      <% end %>
    </div>

    <%= yield %>
  </body>
</html>
